<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.raven.interfaces.GUI.controller.TerminalController"
      styleClass="tab-content"
      spacing="8">

    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
        <Label text="Session ID:" styleClass="muted-text"/>
        <TextField fx:id="sessionIdField"
                   prefWidth="80"
                   styleClass="input-field"/>
        <Label fx:id="selectedAgentLabel"
               text="○ No agent selected"
               styleClass="muted-text"
               HBox.hgrow="ALWAYS"/>
        <Button fx:id="clearBtn" text="Clear" styleClass="btn-outline"/>
    </HBox>

    <TextArea fx:id="terminalOutput"
              editable="false"
              prefHeight="400"
              styleClass="terminal-area"
              VBox.vgrow="ALWAYS"/>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="❯" styleClass="prompt-label"/>
        <TextField fx:id="cmdInputField"
                   promptText="Enter command..."
                   styleClass="input-field"
                   HBox.hgrow="ALWAYS"/>
        <Button fx:id="sendBtn" text="Send" styleClass="btn-accent"/>
    </HBox>
</VBox>
