<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.raven.interfaces.GUI.controller.CommandCenterController"
      styleClass="tab-content"
      spacing="12">

    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

    <VBox fx:id="helpCard" styleClass="panel-card" spacing="8">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
        <TextArea fx:id="helpText"
                  editable="false"
                  prefHeight="120"
                  styleClass="terminal-area"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="❯" styleClass="prompt-danger"/>
        <TextField fx:id="commandInput"
                   promptText="Type GUI command matching CLI syntax..."
                   styleClass="input-field"
                   HBox.hgrow="ALWAYS"/>
        <Button fx:id="runBtn"   text="EXECUTE"    styleClass="btn-danger"/>
        <Button fx:id="clearBtn" text="CLEAR LOGS" styleClass="btn-outline"/>
    </HBox>

    <TextArea fx:id="mirrorOutput"
              editable="false"
              styleClass="terminal-area"
              VBox.vgrow="ALWAYS"/>
</VBox>
