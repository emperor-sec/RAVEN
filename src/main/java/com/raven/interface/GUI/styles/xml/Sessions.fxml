<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.raven.interfaces.GUI.controller.SessionsController"
      styleClass="tab-content"
      spacing="8">

    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="🔍 Search sessions..."
                   styleClass="input-field"
                   prefWidth="220"
                   HBox.hgrow="ALWAYS"/>
        <Button fx:id="refreshBtn"   text="⟳ Refresh"     styleClass="btn-outline"/>
        <Button fx:id="executeBtn"   text="▶ Execute"      styleClass="btn-danger"/>
        <Button fx:id="broadcastBtn" text="⇶ Broadcast"    styleClass="btn-outline"/>
        <Button fx:id="killBtn"      text="⊘ Kill"         styleClass="btn-danger"/>
    </HBox>

    <HBox styleClass="cmd-row" spacing="8" alignment="CENTER_LEFT">
        <padding><Insets top="4" bottom="4"/></padding>
        <Label text="COMMAND:" styleClass="label-danger-bold"/>
        <TextField fx:id="srvInput"
                   promptText="sessions | status | stats | tasks | kill &lt;id&gt; | sysinfo &lt;id&gt; | history [id] [limit] | note &lt;id&gt; &lt;text&gt; | exec &lt;id&gt; &lt;cmd&gt;"
                   styleClass="input-field"
                   HBox.hgrow="ALWAYS"/>
        <Button fx:id="srvExecBtn" text="RUN" styleClass="btn-danger"/>
    </HBox>

    <TableView fx:id="sessionTable"
               styleClass="session-table"
               VBox.vgrow="ALWAYS"/>
</VBox>
