<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.raven.interfaces.GUI.controller.SidebarController"
      styleClass="sidebar"
      prefWidth="240">

    <VBox styleClass="logo-block" spacing="8">
        <padding><Insets top="28" right="22" bottom="18" left="22"/></padding>
        <Label fx:id="iconLabel"  text="◆"         styleClass="logo-icon"/>
        <Label fx:id="nameLabel"  text="RAVEN"      styleClass="logo-name"/>
        <Label fx:id="tagLabel"   text="Black Ops Console" styleClass="logo-tag"/>
    </VBox>

    <Separator styleClass="sidebar-divider"/>

    <VBox fx:id="metaBlock" styleClass="meta-block" spacing="12" VBox.vgrow="ALWAYS">
        <padding><Insets top="18" right="22" bottom="18" left="22"/></padding>
    </VBox>

    <VBox styleClass="sidebar-footer" spacing="8">
        <padding><Insets top="14" right="22" bottom="18" left="22"/></padding>
        <Label fx:id="statusLabel"  text="● Offline"    styleClass="status-offline"/>
        <Label fx:id="authorLabel"  text="MatrixTM26"   styleClass="muted-text"/>
    </VBox>
</VBox>
