<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>

<GridPane xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.raven.interfaces.GUI.controller.LoginController"
          hgap="12"
          vgap="8"
          styleClass="login-grid">

    <padding><Insets top="20" right="20" bottom="10" left="20"/></padding>

    <columnConstraints>
        <ColumnConstraints minWidth="80"/>
        <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>

    <Label text="Username:" styleClass="muted-text" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
    <TextField fx:id="userField"
               promptText="Username"
               styleClass="input-field"
               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

    <Label text="Password:" styleClass="muted-text" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
    <PasswordField fx:id="passField"
                   promptText="Password"
                   styleClass="input-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

    <Label fx:id="errLabel"
           text=""
           styleClass="label-danger"
           GridPane.columnIndex="1" GridPane.rowIndex="2"/>
</GridPane>
