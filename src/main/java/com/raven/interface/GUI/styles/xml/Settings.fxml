<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.raven.interfaces.GUI.controller.SettingsController"
            fitToWidth="true"
            styleClass="tab-scroll">

    <VBox styleClass="tab-content" spacing="16">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

        <VBox fx:id="serverCard" styleClass="panel-card" spacing="8">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <GridPane hgap="16" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="50"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
                <Label text="Host:" styleClass="muted-text" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="hostField" styleClass="input-field"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label text="Port:" styleClass="muted-text" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="portField" styleClass="input-field"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            </GridPane>

            <HBox spacing="8">
                <Button fx:id="startBtn" text="▶ START SERVER" styleClass="btn-danger"/>
                <Button fx:id="stopBtn"  text="◼ STOP SERVER"  styleClass="btn-danger" disable="true"/>
            </HBox>
        </VBox>

        <VBox fx:id="statusCard" styleClass="panel-card" spacing="8">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <Label fx:id="serverStatusLabel" text="● OFFLINE" styleClass="server-status-offline"/>
            <Label fx:id="serverInfoLabel"   text="Not running" styleClass="muted-text"/>
        </VBox>
    </VBox>
</ScrollPane>
