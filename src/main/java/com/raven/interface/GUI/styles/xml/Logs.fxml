<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.raven.interfaces.GUI.controller.LogsController"
      styleClass="tab-content"
      spacing="8">

    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_RIGHT">
        <Button fx:id="exportBtn" text="Export" styleClass="btn-outline"/>
        <Button fx:id="clearBtn"  text="Clear"  styleClass="btn-danger"/>
    </HBox>

    <TextArea fx:id="logOutput"
              editable="false"
              styleClass="terminal-area"
              VBox.vgrow="ALWAYS"/>
</VBox>
