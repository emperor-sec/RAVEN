<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.raven.interfaces.GUI.controller.TopBarController"
      styleClass="topbar"
      prefHeight="72"
      alignment="CENTER_LEFT">

    <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>

    <VBox spacing="2">
        <Label text="RAVEN Operations Console" styleClass="topbar-title"/>
        <Label text="Listener control • Session ops • CLI-aligned command center" styleClass="topbar-sub"/>
    </VBox>

    <Region HBox.hgrow="ALWAYS"/>

    <HBox fx:id="rightCluster" spacing="16" alignment="CENTER_RIGHT">
        <Label fx:id="uptimeLabel"       text="00:00:00"    styleClass="muted-text"/>
        <Region styleClass="v-divider"/>
        <Label fx:id="sessionCountLabel" text="⊟ 0 Sessions" styleClass="accent-text"/>
        <Label fx:id="operatorLabel"     styleClass="accent-text" managed="false" visible="false"/>
    </HBox>
</HBox>
